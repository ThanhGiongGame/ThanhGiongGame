  m_Script: {fileID: 11500000, guid: d1e4846ae98bb674fa13543877b4a222, type: 3}
  m_Name: Opening_Cutscene_Manager_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - characterName: "Th\xE1nh Gi\xF3ng"
    text: "N\u01B0\u1EDBc nh\xE0 l\xE2m nguy, l\xE0m trai ph\u1EA3i ra s\u1EE9c \u0111\u1EC1n
      n\u1EE3 n\u01B0\u1EDBc! Ta \u0111\xE3 s\u1EB5n s\xE0ng!"
    voiceClip: {fileID: 8300000, guid: 3a83bf0103b06ff4ab8242cafbf8bb74, type: 3}
  - characterName: "M\u1EB9 Th\xE1nh Gi\xF3ng"
    text: "Con trai, h\xE3y b\u1EA3o tr\u1ECDng. D\xE2n l\xE0ng lu\xF4n h\u01B0\u1EDBng
      v\u1EC1 con."
    voiceClip: {fileID: 8300000, guid: 7aa417e683727eb47b1ac6b07fb4bb78, type: 3}
